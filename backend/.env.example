# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=4000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=learn_hub

# Aiven / cloud MySQL: enable TLS (required for remote connections)
# DB_SSL=true

# JWT — use long random strings in production (openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Production (Render + Vercel): set NODE_ENV=production and list your frontend origin(s).
# CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com

# Required when frontend and API are on different domains (HTTPS): refresh cookie must be Secure + SameSite=None.
# COOKIE_SECURE=true

# Optional: only if you use a shared parent domain for cookies (uncommon for Render hostnames).
# COOKIE_DOMAIN=.yourdomain.com
