# Copy to `.env.local` for local overrides. On Vercel, set `VITE_API_URL` in Project → Environment Variables.

# Local backend (default in code is already http://localhost:4000/api):
# VITE_API_URL=http://localhost:4000/api

# Production (your Render Web Service URL + /api):
# VITE_API_URL=https://your-service-name.onrender.com/api

# Backend (Render) also needs: NODE_ENV, CORS_ORIGINS, COOKIE_SECURE=true, DB_SSL=true for Aiven — see backend/.env.example
